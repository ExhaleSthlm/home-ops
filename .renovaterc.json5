{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "local>ExhaleSthlm/home-ops//.renovate/autoMerge.json5",
    "local>ExhaleSthlm/home-ops//.renovate/customManagers.json5",
    "local>ExhaleSthlm/home-ops//.renovate/grafanaDashboards.json5",
    "local>ExhaleSthlm/home-ops//.renovate/groups.json5",
    "local>ExhaleSthlm/home-ops//.renovate/labels.json5",
    "local>ExhaleSthlm/home-ops//.renovate/overrides.json5",
    "local>ExhaleSthlm/home-ops//.renovate/semanticCommits.json5",
    ":automergeBranch",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":gitSignOff",
    ":semanticCommits",
    ":timezone(Europe/Stockholm)",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  // Create PRs immediately when updates are found.
  prCreation: "immediate",
  // Recreate updates even if a previous Renovate PR for the same branch was closed.
  recreateWhen: "always",
  // Do not throttle update PR creation.
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  ignorePaths: ["**/resources/**"],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
